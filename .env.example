# Neon direct/unpooled URL for migrations and ingestion.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Neon supplies this direct connection for migrations.
DATABASE_URL_UNPOOLED=
# Optional pooled/read-replica URL for public serving queries.
DATABASE_READ_URL=

# Created by a Vercel Blob integration.
BLOB_READ_WRITE_TOKEN=

# MotherDuck's Vercel integration supplies the service token.
MOTHERDUCK_TOKEN=
# Optional override; defaults to the current US East AWS endpoint.
MOTHERDUCK_PG_HOST=pg.us-east-1-aws.motherduck.com

# Protects ingestion endpoints.
INGEST_SECRET=replace-with-a-long-random-value
