    "db:reconcile": "tsx --env-file=.env.local scripts/reconcile.ts",
    "ingest:local": "tsx --env-file=.env.local scripts/ingest-local.ts",
    "archive:blob": "tsx --env-file=.env.local scripts/archive-blob.ts",
    "profile": "tsx scripts/profile-data.ts",
